#include <neighbors/ivf_flat/detail/jit_lto_kernels/device_functions.cuh>
#include <neighbors/ivf_flat/detail/jit_lto_kernels/post_process_impl.cuh>

namespace cuvs::neighbors::ivf_flat::detail {

// Instantiate the device function template
template <>
__device__ float post_process<float>(float val)
{
  return post_process_@post_process_name@_impl<float>(val);
}

}  // namespace cuvs::neighbors::ivf_flat::detail
