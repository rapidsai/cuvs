#include <neighbors/ivf_flat/detail/jit_lto_kernels/interleaved_scan_impl.cuh>
#include <neighbors/ivf_flat/detail/jit_lto_kernels/kernel_def.hpp>

namespace {

using data_t             = @data_type@;
using acc_t              = @acc_type@;
using index_t            = @index_type@;
constexpr int capacity   = @capacity@;
constexpr bool ascending = @ascending_value@;

}  // namespace

namespace cuvs::neighbors::ivf_flat::detail {

extern "C" __global__ __launch_bounds__(kThreadsPerBlock) void interleaved_scan(
  const uint32_t query_smem_elems,
  const data_t* query,
  const uint32_t* coarse_index,
  const data_t* const* list_data_ptrs,
  const uint32_t* list_sizes,
  const uint32_t queries_offset,
  const uint32_t n_probes,
  const uint32_t k,
  const uint32_t max_samples,
  const uint32_t* chunk_indices,
  const uint32_t dim,
  index_t* const* const inds_ptrs,
  uint32_t* bitset_ptr,
  index_t bitset_len,
  index_t original_nbits,
  uint32_t* neighbors,
  float* distances)
{
  interleaved_scan_impl<data_t, acc_t, index_t, capacity, ascending>(query_smem_elems,
                                                                     query,
                                                                     coarse_index,
                                                                     list_data_ptrs,
                                                                     list_sizes,
                                                                     queries_offset,
                                                                     n_probes,
                                                                     k,
                                                                     max_samples,
                                                                     chunk_indices,
                                                                     dim,
                                                                     inds_ptrs,
                                                                     bitset_ptr,
                                                                     bitset_len,
                                                                     original_nbits,
                                                                     neighbors,
                                                                     distances);
}

static_assert(std::is_same_v<decltype(interleaved_scan), interleaved_scan_func_t<data_t, index_t>>);

}  // namespace cuvs::neighbors::ivf_flat::detail
