#include <neighbors/ivf_pq/detail/jit_lto_kernels/device_functions.cuh>
#include <neighbors/ivf_pq/detail/jit_lto_kernels/increment_score_impl.cuh>

namespace {

using out_t              = @out_type@;
constexpr bool increment = @increment@;

}  // namespace

namespace cuvs::neighbors::ivf_pq::detail {

template <>
__device__ out_t increment_score(out_t score)
{
  return increment_score_impl<out_t, increment>(score);
}

}  // namespace cuvs::neighbors::ivf_pq::detail
