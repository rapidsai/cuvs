#include <neighbors/ivf_pq/detail/jit_lto_kernels/compute_similarity_impl.cuh>
#include <neighbors/ivf_pq/ivf_pq_fp_8bit.cuh>

namespace {

using out_t = @out_type@;
using lut_t = @lut_type@;

}  // namespace

extern "C" __global__ void compute_similarity(
  uint32_t dim,
  uint32_t n_probes,
  uint32_t pq_dim,
  uint32_t n_queries,
  uint32_t queries_offset,
  cuvs::distance::DistanceType metric,
  cuvs::neighbors::ivf_pq::codebook_gen codebook_kind,
  uint32_t topk,
  uint32_t max_samples,
  const float* cluster_centers,
  const float* pq_centers,
  const uint8_t* const* pq_dataset,
  const uint32_t* cluster_labels,
  const uint32_t* _chunk_indices,
  const float* queries,
  const uint32_t* index_list,
  float* query_kths,
  cuvs::neighbors::filtering::ivf_filter_dev sample_filter,
  lut_t* lut_scores,
  out_t* _out_scores,
  uint32_t* _out_indices)
{
  cuvs::neighbors::ivf_pq::detail::compute_similarity_impl<out_t, lut_t>(dim,
                                                                         n_probes,
                                                                         pq_dim,
                                                                         n_queries,
                                                                         queries_offset,
                                                                         metric,
                                                                         codebook_kind,
                                                                         topk,
                                                                         max_samples,
                                                                         cluster_centers,
                                                                         pq_centers,
                                                                         pq_dataset,
                                                                         cluster_labels,
                                                                         _chunk_indices,
                                                                         queries,
                                                                         index_list,
                                                                         query_kths,
                                                                         sample_filter,
                                                                         lut_scores,
                                                                         _out_scores,
                                                                         _out_indices);
}
