#include <neighbors/detail/cagra/compute_distance_vpq-impl.cuh>

namespace {

using namespace cuvs::distance;
constexpr auto metric        = DistanceType::@metric@;
constexpr uint32_t team_size = @team_size@;
constexpr uint32_t dim       = @dim@;
constexpr uint32_t pq_bits   = @pq_bits@;
constexpr uint32_t pq_len    = @pq_len@;
using codebook_t             = @codebook_type@;
using data_t                 = @data_type@;
using index_t                = @index_type@;
using distance_t             = @distance_type@;

}  // namespace

namespace cuvs::neighbors::cagra::detail {

template struct vpq_descriptor_spec<metric,
                                    team_size,
                                    dim,
                                    pq_bits,
                                    pq_len,
                                    codebook_t,
                                    data_t,
                                    index_t,
                                    distance_t>;

}  // namespace cuvs::neighbors::cagra::detail
