#include <cstdint>

#include <neighbors/detail/cagra/jit_lto_kernels/dist_op_impl.cuh>

namespace cuvs::neighbors::cagra::detail {

using query_t    = @query_type@;
using distance_t = @distance_type@;

template <>
__device__ distance_t dist_op<query_t, distance_t>(query_t a, query_t b)
{
  return dist_op_@metric_tag@_impl<query_t, distance_t>(a, b);
}

}  // namespace cuvs::neighbors::cagra::detail
