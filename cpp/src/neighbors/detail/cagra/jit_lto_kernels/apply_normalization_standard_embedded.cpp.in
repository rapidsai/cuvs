#include "@embedded_header_file@"
#include <cuvs/detail/jit_lto/RegisterKernelFragment.hpp>
#include <cuvs/detail/jit_lto/registration_tags.hpp>

using namespace cuvs::neighbors::cagra::detail;

namespace {

__attribute__((__constructor__)) void register_kernel()
{
  using QueryTag = cuvs::neighbors::cagra::detail::tag_@query_abbrev@;
  registerAlgorithm<tag_@data_abbrev@, tag_idx_@index_abbrev@, tag_dist_@distance_abbrev@, QueryTag>(
    "apply_normalization_standard_@norm_kind@_team_size_@team_size@_dataset_block_dim_@dataset_block_dim@",
    embedded_fatbin,
    sizeof(embedded_fatbin));
}

}  // namespace
