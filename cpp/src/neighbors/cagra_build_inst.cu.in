#include <cuvs/core/cuda_fp16.hpp>

#include <cuvs/neighbors/cagra.hpp>
#include <neighbors/cagra.cuh>

#include <memory>

namespace {

using data_t                      = @data_type@;
using index_t                     = @index_type@;
using inst_device_padded_view_t   = cuvs::neighbors::device_padded_dataset_view<data_t, int64_t>;
using inst_device_standard_view_t = cuvs::neighbors::device_standard_dataset_view<data_t, int64_t>;
using inst_host_padded_view_t     = cuvs::neighbors::host_padded_dataset_view<data_t, int64_t>;
using inst_host_standard_view_t   = cuvs::neighbors::host_standard_dataset_view<data_t, int64_t>;
using inst_vpq_f16_view_t         = cuvs::neighbors::device_vpq_dataset_view<half, int64_t>;
using inst_vpq_f32_view_t         = cuvs::neighbors::device_vpq_dataset_view<float, int64_t>;

}  // namespace

namespace cuvs::neighbors::cagra {

void build_knn_graph(raft::resources const& handle,
                     raft::host_matrix_view<const data_t, int64_t, raft::row_major> dataset,
                     raft::host_matrix_view<index_t, int64_t, raft::row_major> knn_graph,
                     cuvs::neighbors::cagra::graph_build_params::ivf_pq_params params)
{
  cuvs::neighbors::cagra::build_knn_graph<data_t, index_t>(handle, dataset, knn_graph, params);
}

#define CUVS_INST_CAGRA_BUILD(DatasetViewT)                              \
  template CUVS_EXPORT auto cuvs::neighbors::cagra::build<DatasetViewT>( \
    raft::resources const& res,                                          \
    const cuvs::neighbors::cagra::index_params& params,                  \
    DatasetViewT const& dataset) -> cuvs::neighbors::cagra::cagra_index_t<DatasetViewT>

CUVS_INST_CAGRA_BUILD(inst_device_padded_view_t);
CUVS_INST_CAGRA_BUILD(inst_device_standard_view_t);
CUVS_INST_CAGRA_BUILD(inst_host_padded_view_t);
CUVS_INST_CAGRA_BUILD(inst_host_standard_view_t);
CUVS_INST_CAGRA_BUILD(inst_vpq_f16_view_t);
CUVS_INST_CAGRA_BUILD(inst_vpq_f32_view_t);

#undef CUVS_INST_CAGRA_BUILD

}  // namespace cuvs::neighbors::cagra
