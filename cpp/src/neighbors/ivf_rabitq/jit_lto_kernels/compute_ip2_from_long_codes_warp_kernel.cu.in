#include <neighbors/ivf_rabitq/jit_lto_kernels/device_functions.cuh>

#include <raft/util/cuda_dev_essentials.cuh>

namespace cuvs::neighbors::ivf_rabitq::detail {

// Non-inline __device__ definition. ex_bits is folded into the called
// extract_code fragment (same matrix.json axis value), so this fragment's
// inner D-loop becomes specialized end-to-end. Each matrix.json value
// produces a separate fragment with the same mangled C++ symbol; the planner
// adds exactly one via
// add_compute_ip2_from_long_codes_warp_device_function<ex_bits>(), and
// nvJitLink resolves the consumer's call (and this fragment's call into
// extract_code) at link time. Keep in sync with the inline form in
// searcher_gpu_common.cuh used by the legacy __global__ kernels.
__device__ float compute_ip2_from_long_codes_warp(const uint8_t* vec_long_code,
                                                  const float* shared_query,
                                                  size_t D,
                                                  int lane_id)
{
  float ip2 = 0.0f;
  for (size_t d = lane_id; d < D; d += raft::WarpSize) {
    uint32_t code_val = extract_code(vec_long_code, d);
    ip2 += shared_query[d] * static_cast<float>(code_val);
  }
#pragma unroll
  for (int offset = raft::WarpSize / 2; offset > 0; offset /= 2) {
    ip2 += __shfl_down_sync(0xFFFFFFFF, ip2, offset);
  }
  return ip2;
}

}  // namespace cuvs::neighbors::ivf_rabitq::detail
