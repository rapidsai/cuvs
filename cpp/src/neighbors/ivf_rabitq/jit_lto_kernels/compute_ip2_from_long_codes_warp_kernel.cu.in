#include <neighbors/ivf_rabitq/jit_lto_kernels/device_functions.cuh>

#include <raft/util/cuda_dev_essentials.cuh>

namespace cuvs::neighbors::ivf_rabitq::detail {

// Templated __device__ implementation. Lets the inner D-loop's
// extract_code<EX_BITS> call constant-fold its bit-extraction arithmetic.
template <int EX_BITS>
__device__ float compute_ip2_from_long_codes_warp_impl(const uint8_t* vec_long_code,
                                                       const float* shared_query,
                                                       size_t D,
                                                       int lane_id)
{
  float ip2 = 0.0f;
  for (size_t d = lane_id; d < D; d += raft::WarpSize) {
    uint32_t code_val = extract_code<EX_BITS>(vec_long_code, d);
    ip2 += shared_query[d] * static_cast<float>(code_val);
  }
#pragma unroll
  for (int offset = raft::WarpSize / 2; offset > 0; offset /= 2) {
    ip2 += __shfl_down_sync(0xFFFFFFFF, ip2, offset);
  }
  return ip2;
}

template __device__ float compute_ip2_from_long_codes_warp_impl<1>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<2>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<3>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<4>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<5>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<6>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<7>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);
template __device__ float compute_ip2_from_long_codes_warp_impl<8>(const uint8_t*,
                                                                   const float*,
                                                                   size_t,
                                                                   int);

// Public dispatcher with runtime EX_BITS. The switch is hoisted by the
// compiler above the candidate loop (EX_BITS is loop-invariant at every
// call site), so the per-call cost amortizes to one branch per kernel
// invocation. Keep in sync with the inline non-templated definition in
// searcher_gpu_common.cuh used by the legacy __global__ kernels.
__device__ float compute_ip2_from_long_codes_warp(
  const uint8_t* vec_long_code, const float* shared_query, size_t D, size_t EX_BITS, int lane_id)
{
  switch (EX_BITS) {
    case 1:
      return compute_ip2_from_long_codes_warp_impl<1>(vec_long_code, shared_query, D, lane_id);
    case 2:
      return compute_ip2_from_long_codes_warp_impl<2>(vec_long_code, shared_query, D, lane_id);
    case 3:
      return compute_ip2_from_long_codes_warp_impl<3>(vec_long_code, shared_query, D, lane_id);
    case 4:
      return compute_ip2_from_long_codes_warp_impl<4>(vec_long_code, shared_query, D, lane_id);
    case 5:
      return compute_ip2_from_long_codes_warp_impl<5>(vec_long_code, shared_query, D, lane_id);
    case 6:
      return compute_ip2_from_long_codes_warp_impl<6>(vec_long_code, shared_query, D, lane_id);
    case 7:
      return compute_ip2_from_long_codes_warp_impl<7>(vec_long_code, shared_query, D, lane_id);
    case 8:
      return compute_ip2_from_long_codes_warp_impl<8>(vec_long_code, shared_query, D, lane_id);
    default: __builtin_unreachable();
  }
}

}  // namespace cuvs::neighbors::ivf_rabitq::detail
