#include <neighbors/ivf_rabitq/jit_lto_kernels/device_functions.cuh>

#include <raft/util/cuda_dev_essentials.cuh>

namespace cuvs::neighbors::ivf_rabitq::detail {

// Non-inline __device__ definition. Other JIT-LTO fragments declare this
// function via device_functions.cuh and reference it across fragments; nvJitLink
// resolves the reference at link time. This fragment in turn calls
// extract_code, also resolved cross-fragment. Keep in sync with the inline
// definition in searcher_gpu_common.cuh that legacy (non-JIT) TUs use.
__device__ float compute_ip2_from_long_codes_warp(
  const uint8_t* vec_long_code, const float* shared_query, size_t D, size_t EX_BITS, int lane_id)
{
  float ip2 = 0.0f;
  for (size_t d = lane_id; d < D; d += raft::WarpSize) {
    uint32_t code_val = extract_code(vec_long_code, d, EX_BITS);
    ip2 += shared_query[d] * static_cast<float>(code_val);
  }
#pragma unroll
  for (int offset = raft::WarpSize / 2; offset > 0; offset /= 2) {
    ip2 += __shfl_down_sync(0xFFFFFFFF, ip2, offset);
  }
  return ip2;
}

}  // namespace cuvs::neighbors::ivf_rabitq::detail
