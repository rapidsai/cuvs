#include <neighbors/ivf_rabitq/jit_lto_kernels/compute_inner_products_with_bitwise_impl.cuh>
#include <neighbors/ivf_rabitq/jit_lto_kernels/kernel_def.hpp>

namespace cuvs::neighbors::ivf_rabitq::detail {

extern "C" __global__ void compute_inner_products_with_bitwise(
  const ComputeInnerProductsKernelParams params)
{
  compute_inner_products_with_bitwise_impl(params);
}

static_assert(std::is_same_v<decltype(compute_inner_products_with_bitwise),
                             compute_inner_products_with_lut_func_t>);

}  // namespace cuvs::neighbors::ivf_rabitq::detail
