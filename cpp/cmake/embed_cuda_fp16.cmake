#
# Invoked as: cmake -DINPUT=<path/to/cuda_fp16.h> -DOUTPUT=<path.cpp> -P embed_cuda_fp16.cmake
# Writes a .cpp defining null-terminated k_nvrtc_embedded_cuda_fp16_h[] from the toolkit file.

if(NOT DEFINED INPUT OR NOT DEFINED OUTPUT)
  message(FATAL_ERROR "embed_cuda_fp16.cmake requires -DINPUT= and -DOUTPUT=")
endif()
if(NOT EXISTS "${INPUT}")
  message(FATAL_ERROR "cuda_fp16.h not found: ${INPUT}")
endif()

file(READ "${INPUT}" _hex HEX)
string(REGEX REPLACE "([0-9a-fA-F][0-9a-fA-F])" "0x\\1, " _bytes "${_hex}")

file(
  WRITE "${OUTPUT}"
  "// SPDX-FileCopyrightText: Copyright (c) 2026, NVIDIA CORPORATION.\n"
  "// SPDX-License-Identifier: Apache-2.0\n"
  "//\n"
  "// Generated by embed_cuda_fp16.cmake — do not edit.\n"
  "// Source: ${INPUT}\n"
  "\n"
  "namespace cuvs::detail::jit_lto {\n"
  "\n"
  "char const k_nvrtc_embedded_cuda_fp16_h[] = { ${_bytes}0x00 };\n"
  "\n"
  "}  // namespace cuvs::detail::jit_lto\n"
)
